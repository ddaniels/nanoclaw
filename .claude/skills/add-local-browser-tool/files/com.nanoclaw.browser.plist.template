<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.nanoclaw.browser</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Applications/Google Chrome.app/Contents/MacOS/Google Chrome</string>
        <string>--remote-debugging-port=9222</string>
        <string>--remote-debugging-address=127.0.0.1</string>
        <string>--remote-allow-origins=*</string>
        <string>--user-data-dir={HOME}/.nanoclaw-browser-profile</string>
        <string>--no-first-run</string>
        <string>--no-default-browser-check</string>
        <string>--disable-features=ChromeWhatsNewUI</string>
        <!--
            AutomationControlled is the blink feature that sets
            navigator.webdriver = true when CDP is attached.
            Disabling it removes the most-checked PerimeterX/Cloudflare
            bot signal so the agent's tabs look like normal user tabs.
        -->
        <string>--disable-blink-features=AutomationControlled</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/nanoclaw-browser.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/nanoclaw-browser.err.log</string>
</dict>
</plist>
